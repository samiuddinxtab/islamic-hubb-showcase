---
import programsData from '../../content/data/programs.json';
import FadeIn from '../animations/FadeIn.astro';

const { programs } = programsData;
const featuredPrograms = programs.filter(p => p.featured).slice(0, 3);
---

<section class="section-padding bg-gray-50">
  <div class="container-custom">
    <FadeIn class="text-center max-w-3xl mx-auto mb-16">
      <span class="badge badge-secondary mb-4">Learning Paths</span>
      <h2 class="section-title">Structured Programs for Every Journey</h2>
      <p class="section-subtitle">
        Whether you're beginning your Islamic education or seeking advanced scholarship, 
        we have a program designed for your goals.
      </p>
    </FadeIn>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {featuredPrograms.map((program, index) => (
        <FadeIn delay={index * 0.1} class="group">
          <div class="h-full bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-500 border border-gray-100 hover:border-emerald-200">
            <div class="p-8">
              <div class="flex items-center justify-between mb-4">
                <span class="badge badge-primary">{program.duration}</span>
                <span class="text-sm text-gray-500">{program.commitment}</span>
              </div>
              
              <h3 class="text-2xl font-bold text-gray-900 mb-2">{program.title}</h3>
              <p class="text-emerald-600 font-medium mb-4">{program.subtitle}</p>
              <p class="text-gray-600 mb-6 line-clamp-3">{program.description}</p>

              <div class="space-y-4 mb-6">
                <div>
                  <h4 class="text-sm font-semibold text-gray-900 mb-2">Key Courses:</h4>
                  <ul class="space-y-1">
                    {program.courses.slice(0, 3).map((course) => (
                      <li class="flex items-center gap-2 text-sm text-gray-600">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        {course}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <a 
                href={`/programs/${program.id}`}
                class="inline-flex items-center gap-2 text-emerald-600 font-medium hover:text-emerald-700 transition-colors group/link"
              >
                Learn More
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transform group-hover/link:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
            
            <!-- Bottom Accent -->
            <div class="h-1 bg-gradient-to-r from-emerald-500 to-teal-600 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
          </div>
        </FadeIn>
      ))}
    </div>

    <FadeIn delay={0.4} class="text-center mt-12">
      <a href="/programs" class="btn-outline">
        View All Programs
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </FadeIn>
  </div>
</section>
