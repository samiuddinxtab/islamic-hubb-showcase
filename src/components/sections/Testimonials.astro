---
import testimonialsData from '../../content/data/testimonials.json';
import FadeIn from '../animations/FadeIn.astro';

const { testimonials } = testimonialsData;
const featuredTestimonials = testimonials.slice(0, 3);
---

<section class="section-padding bg-gradient-to-br from-emerald-900 via-teal-900 to-emerald-800 relative overflow-hidden">
  <!-- Background Pattern -->
  <div class="absolute inset-0 opacity-5">
    <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
  </div>

  <div class="container-custom relative z-10">
    <FadeIn class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm rounded-full text-emerald-100 text-sm font-medium mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        Student Testimonials
      </span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4">
        What Our Students Say
      </h2>
      <p class="text-lg text-emerald-100/80">
        Join thousands of satisfied students who have transformed their lives through our programs.
      </p>
    </FadeIn>

    <div class="grid md:grid-cols-3 gap-8">
      {featuredTestimonials.map((testimonial, index) => (
        <FadeIn delay={index * 0.15}>
          <div class="h-full bg-white/10 backdrop-blur-sm rounded-2xl p-8 border border-white/20 hover:bg-white/15 transition-all duration-500">
            <!-- Stars -->
            <div class="flex gap-1 mb-6">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg 
                  xmlns="http://www.w3.org/2000/svg" 
                  class={`h-5 w-5 ${i < testimonial.rating ? 'text-amber-400' : 'text-gray-400'}`}
                  fill="currentColor" 
                  viewBox="0 0 24 24"
                >
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>

            <!-- Quote -->
            <blockquote class="text-white/90 mb-6 leading-relaxed">
              "{testimonial.content}"
            </blockquote>

            <!-- Author -->
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-emerald-400 to-teal-500 flex items-center justify-center text-white font-bold">
                {testimonial.name.split(' ').map(n => n[0]).join('')}
              </div>
              <div>
                <div class="font-semibold text-white">{testimonial.name}</div>
                <div class="text-sm text-emerald-200">{testimonial.role}</div>
                <div class="text-xs text-emerald-300/70 mt-1">{testimonial.courseTaken}</div>
              </div>
            </div>
          </div>
        </FadeIn>
      ))}
    </div>

    <FadeIn delay={0.5} class="text-center mt-12">
      <a href="/testimonials" class="inline-flex items-center gap-2 text-white font-medium hover:text-emerald-200 transition-colors">
        Read More Testimonials
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </FadeIn>
  </div>
</section>
