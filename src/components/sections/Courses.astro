---
import coursesData from '../../content/data/courses.json';
import FadeIn from '../animations/FadeIn.astro';
import { getCourseCategoryLabel, getCourseLevelLabel } from '../../utils/helpers';

const { courses } = coursesData;
const featuredCourses = courses.slice(0, 6);

const categoryColors: Record<string, string> = {
  quran: 'bg-emerald-100 text-emerald-800',
  arabic: 'bg-amber-100 text-amber-800',
  fiqh: 'bg-blue-100 text-blue-800',
  aqeedah: 'bg-purple-100 text-purple-800',
  hadith: 'bg-rose-100 text-rose-800',
  seerah: 'bg-teal-100 text-teal-800',
  tajweed: 'bg-cyan-100 text-cyan-800',
  'islamic-history': 'bg-indigo-100 text-indigo-800',
};
---

<section class="section-padding bg-white">
  <div class="container-custom">
    <FadeIn class="text-center max-w-3xl mx-auto mb-16">
      <span class="badge badge-primary mb-4">Our Courses</span>
      <h2 class="section-title">Comprehensive Islamic Curriculum</h2>
      <p class="section-subtitle">
        From Quran memorization to Islamic jurisprudence, explore our diverse range of courses 
        taught by qualified scholars.
      </p>
    </FadeIn>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {featuredCourses.map((course, index) => (
        <FadeIn delay={index * 0.1} class="group">
          <article class="h-full bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-500 border border-gray-100 hover:border-emerald-200">
            <!-- Course Header -->
            <div class="relative h-48 bg-gradient-to-br from-emerald-500 to-teal-600 overflow-hidden">
              <div class="absolute inset-0 bg-black/10"></div>
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="text-center text-white/90">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto mb-2 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                  </svg>
                </div>
              </div>
              
              <!-- Badges -->
              <div class="absolute top-4 left-4 flex gap-2">
                <span class={`badge ${categoryColors[course.category] || 'bg-gray-100 text-gray-800'}`}>
                  {getCourseCategoryLabel(course.category)}
                </span>
              </div>
              <div class="absolute top-4 right-4">
                <span class="badge bg-white/90 text-gray-800">
                  {getCourseLevelLabel(course.level)}
                </span>
              </div>
            </div>

            <!-- Course Content -->
            <div class="p-6">
              <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-emerald-600 transition-colors">
                {course.title}
              </h3>
              <p class="text-gray-600 text-sm mb-4 line-clamp-2">{course.description}</p>

              <!-- Meta Info -->
              <div class="flex flex-wrap gap-4 text-sm text-gray-500 mb-4">
                <div class="flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {course.duration}
                </div>
                <div class="flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                  {course.maxStudents} students
                </div>
              </div>

              <!-- Instructor -->
              <div class="flex items-center gap-3 pt-4 border-t border-gray-100">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-emerald-400 to-teal-500 flex items-center justify-center text-white font-semibold">
                  {course.instructor.split(' ').map(n => n[0]).join('').slice(0, 2)}
                </div>
                <div>
                  <p class="text-sm font-medium text-gray-900">{course.instructor}</p>
                  <p class="text-xs text-gray-500">Instructor</p>
                </div>
              </div>
            </div>

            <!-- Action -->
            <div class="px-6 pb-6">
              <a 
                href={`/courses/${course.id}`}
                class="block w-full text-center py-3 rounded-lg border-2 border-emerald-600 text-emerald-600 font-medium hover:bg-emerald-600 hover:text-white transition-all duration-300"
              >
                View Course Details
              </a>
            </div>
          </article>
        </FadeIn>
      ))}
    </div>

    <FadeIn delay={0.5} class="text-center mt-12">
      <a href="/courses" class="btn-primary">
        Browse All Courses
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </FadeIn>
  </div>
</section>
