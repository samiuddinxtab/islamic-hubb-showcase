---
import Layout from '../layouts/Layout.astro';
import FadeIn from '../components/animations/FadeIn.astro';
import testimonialsData from '../content/data/testimonials.json';

const { testimonials } = testimonialsData;

const seo = {
  title: 'Student Testimonials | Islamic Hubb Institute',
  description: 'Read what our students say about their learning experience at Islamic Hubb Institute.',
};
---

<Layout seo={seo}>
  <!-- Hero -->
  <section class="relative py-24 bg-gradient-to-br from-emerald-900 via-teal-900 to-emerald-800">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'0.4\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="container-custom relative z-10">
      <FadeIn class="text-center max-w-3xl mx-auto">
        <span class="badge bg-white/20 text-white mb-4">Testimonials</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
          What Our Students Say
        </h1>
        <p class="text-xl text-emerald-100">
          Discover how Islamic Hubb Institute has transformed the lives of students from around the world.
        </p>
      </FadeIn>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-12 bg-white border-b">
    <div class="container-custom">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <FadeIn>
          <div class="text-center">
            <div class="text-4xl font-bold text-emerald-600 mb-2">5,000+</div>
            <div class="text-gray-600">Students Enrolled</div>
          </div>
        </FadeIn>
        <FadeIn delay={0.1}>
          <div class="text-center">
            <div class="text-4xl font-bold text-emerald-600 mb-2">98%</div>
            <div class="text-gray-600">Satisfaction Rate</div>
          </div>
        </FadeIn>
        <FadeIn delay={0.2}>
          <div class="text-center">
            <div class="text-4xl font-bold text-emerald-600 mb-2">50+</div>
            <div class="text-gray-600">Countries</div>
          </div>
        </FadeIn>
        <FadeIn delay={0.3}>
          <div class="text-center">
            <div class="text-4xl font-bold text-emerald-600 mb-2">100+</div>
            <div class="text-gray-600">Courses</div>
          </div>
        </FadeIn>
      </div>
    </div>
  </section>

  <!-- Testimonials Grid -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {testimonials.map((testimonial, index) => (
          <FadeIn delay={index * 0.1}>
            <div class="h-full bg-white rounded-2xl p-8 shadow-md hover:shadow-lg transition-shadow">
              <!-- Stars -->
              <div class="flex gap-1 mb-6">
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg 
                    xmlns="http://www.w3.org/2000/svg" 
                    class={`h-5 w-5 ${i < testimonial.rating ? 'text-amber-400' : 'text-gray-300'}`}
                    fill="currentColor" 
                    viewBox="0 0 24 24"
                  >
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                ))}
              </div>

              <!-- Quote -->
              <blockquote class="text-gray-700 mb-6 leading-relaxed">
                "{testimonial.content}"
              </blockquote>

              <!-- Author -->
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-gradient-to-br from-emerald-400 to-teal-500 flex items-center justify-center text-white font-bold">
                  {testimonial.name.split(' ').map(n => n[0]).join('')}
                </div>
                <div>
                  <div class="font-semibold text-gray-900">{testimonial.name}</div>
                  <div class="text-sm text-gray-500">{testimonial.role}</div>
                  <div class="text-xs text-emerald-600 mt-1">{testimonial.courseTaken}</div>
                </div>
              </div>
            </div>
          </FadeIn>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-emerald-600">
    <div class="container-custom">
      <FadeIn>
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-3xl font-bold text-white mb-4">
            Join Our Community of Learners
          </h2>
          <p class="text-emerald-100 mb-8">
            Start your journey of Islamic knowledge today and become part of our growing community.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href="/courses" class="btn bg-white text-emerald-600 hover:bg-emerald-50">
              Browse Courses
            </a>
            <a href="/contact" class="btn border-2 border-white text-white hover:bg-white/10">
              Get in Touch
            </a>
          </div>
        </div>
      </FadeIn>
    </div>
  </section>
</Layout>
