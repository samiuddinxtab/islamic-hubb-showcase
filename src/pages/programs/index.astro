---
import Layout from '../../layouts/Layout.astro';
import FadeIn from '../../components/animations/FadeIn.astro';
import programsData from '../../content/data/programs.json';
import seoData from '../../content/data/seo.json';

const { programs } = programsData;
const seo = seoData.pages.programs;
---

<Layout seo={seo}>
  <!-- Hero -->
  <section class="relative py-24 bg-gradient-to-br from-emerald-900 via-teal-900 to-emerald-800">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'0.4\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="container-custom relative z-10">
      <FadeIn class="text-center max-w-3xl mx-auto">
        <span class="badge bg-white/20 text-white mb-4">Programs</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
          Learning Paths
        </h1>
        <p class="text-xl text-emerald-100">
          Structured programs designed to take you from foundation to expertise in Islamic sciences.
        </p>
      </FadeIn>
    </div>
  </section>

  <!-- Programs Grid -->
  <section class="section-padding bg-gray-50">
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-8">
        {programs.map((program, index) => (
          <FadeIn delay={index * 0.1}>
            <article class="h-full bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-500 border border-gray-100 hover:border-emerald-200">
              <div class="p-8">
                <div class="flex items-center justify-between mb-4">
                  <div class="flex items-center gap-3">
                    <span class="badge badge-primary">{program.duration}</span>
                    <span class="text-sm text-gray-500">{program.commitment}</span>
                  </div>
                  {program.featured && (
                    <span class="badge badge-secondary">Featured</span>
                  )}
                </div>

                <h2 class="text-2xl font-bold text-gray-900 mb-2">{program.title}</h2>
                <p class="text-emerald-600 font-medium mb-4">{program.subtitle}</p>
                <p class="text-gray-600 mb-6">{program.description}</p>

                <div class="grid md:grid-cols-2 gap-6 mb-8">
                  <div>
                    <h3 class="text-sm font-semibold text-gray-900 mb-3 flex items-center gap-2">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                      </svg>
                      Courses Included
                    </h3>
                    <ul class="space-y-2">
                      {program.courses.map((course) => (
                        <li class="flex items-center gap-2 text-sm text-gray-600">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                          </svg>
                          {course}
                        </li>
                      ))}
                    </ul>
                  </div>

                  <div>
                    <h3 class="text-sm font-semibold text-gray-900 mb-3 flex items-center gap-2">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      Learning Outcomes
                    </h3>
                    <ul class="space-y-2">
                      {program.outcomes.map((outcome) => (
                        <li class="flex items-center gap-2 text-sm text-gray-600">
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                          </svg>
                          {outcome}
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>

                <div class="flex gap-4">
                  <a 
                    href={`/programs/${program.id}`}
                    class="btn-primary flex-1 justify-center"
                  >
                    Learn More
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </a>
                  <a 
                    href="/contact"
                    class="btn-outline flex-1 justify-center"
                  >
                    Enroll Now
                  </a>
                </div>
              </div>
            </article>
          </FadeIn>
        ))}
      </div>
    </div>
  </section>
</Layout>
