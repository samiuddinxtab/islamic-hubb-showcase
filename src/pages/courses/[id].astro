---
import Layout from '../../layouts/Layout.astro';
import FadeIn from '../../components/animations/FadeIn.astro';
import coursesData from '../../content/data/courses.json';
import { getCourseCategoryLabel, getCourseLevelLabel } from '../../utils/helpers';

export function getStaticPaths() {
  const { courses } = coursesData;
  return courses.map((course) => ({
    params: { id: course.id },
    props: { course },
  }));
}

const { course } = Astro.props;

const categoryColors: Record<string, string> = {
  tajweed: 'bg-emerald-100 text-emerald-800',
  hifz: 'bg-amber-100 text-amber-800',
  'ibadur-rahman': 'bg-blue-100 text-blue-800',
  momina: 'bg-rose-100 text-rose-800',
  alimiyat: 'bg-purple-100 text-purple-800',
};

const seo = {
  title: `${course.title} | Islamic Hubb`,
  description: course.description,
};
---

<Layout seo={seo}>
  <!-- Hero -->
  <section class="relative py-24 bg-gradient-to-br from-emerald-900 via-teal-900 to-emerald-800">
    <div class="container-custom relative z-10">
      <FadeIn>
        <div class="max-w-4xl mx-auto text-center">
          <div class="flex flex-wrap justify-center gap-2 mb-6">
            <span class={`badge ${categoryColors[course.category] || 'bg-gray-100 text-gray-800'}`}>
              {getCourseCategoryLabel(course.category)}
            </span>
            <span class="badge bg-white/20 text-white">
              {getCourseLevelLabel(course.level)}
            </span>
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
            {course.title}
          </h1>
          <p class="text-xl text-emerald-100 max-w-2xl mx-auto">
            {course.description}
          </p>
        </div>
      </FadeIn>
    </div>
  </section>

  <!-- Course Details -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Main Content -->
        <div class="lg:col-span-2">
          <FadeIn>
            <div class="prose prose-lg max-w-none">
              <h2 class="text-3xl font-bold text-gray-900 mb-6">About This Course</h2>
              {course.introduction && (
                <p class="text-gray-600 leading-relaxed mb-6">{course.introduction}</p>
              )}
              <p class="text-gray-600 leading-relaxed">{course.description}</p>
            </div>
          </FadeIn>

          <FadeIn delay={0.1}>
            <div class="mt-12">
              <h2 class="text-2xl font-bold text-gray-900 mb-6">What You'll Learn</h2>
              <div class="grid md:grid-cols-2 gap-4">
                {course.features.map((feature, idx) => (
                  <div class="flex items-start gap-3 p-4 bg-gray-50 rounded-xl">
                    <div class="w-6 h-6 rounded-full bg-emerald-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    <span class="text-gray-700">{feature}</span>
                  </div>
                ))}
              </div>
            </div>
          </FadeIn>

          {course.targetAudience && course.targetAudience.length > 0 && (
            <FadeIn delay={0.15}>
              <div class="mt-12">
                <h2 class="text-2xl font-bold text-gray-900 mb-6">Who Is This Course For?</h2>
                <div class="grid md:grid-cols-2 gap-4">
                  {course.targetAudience.map((audience, idx) => (
                    <div class="flex items-start gap-3 p-4 bg-blue-50 rounded-xl border-l-4 border-blue-500">
                      <div class="w-6 h-6 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                        </svg>
                      </div>
                      <span class="text-gray-700">{audience}</span>
                    </div>
                  ))}
                </div>
              </div>
            </FadeIn>
          )}

          <FadeIn delay={0.2}>
            <div class="mt-12">
              <h2 class="text-2xl font-bold text-gray-900 mb-6">Curriculum</h2>
              <div class="space-y-3">
                {course.curriculum.map((item, idx) => (
                  <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-xl border-l-4 border-emerald-500">
                    <span class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-600 font-semibold text-sm flex-shrink-0">
                      {idx + 1}
                    </span>
                    <span class="text-gray-700">{item}</span>
                  </div>
                ))}
              </div>
            </div>
          </FadeIn>

          <FadeIn delay={0.3}>
            <div class="mt-12">
              <h2 class="text-2xl font-bold text-gray-900 mb-6">Program Rules</h2>
              <div class="grid md:grid-cols-2 gap-4">
                {course.rules.map((rule) => (
                  <div class="flex items-start gap-3 p-4 bg-emerald-50 rounded-xl">
                    <div class="w-6 h-6 rounded-full bg-emerald-500 flex items-center justify-center flex-shrink-0 mt-0.5">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    <span class="text-gray-700">{rule}</span>
                  </div>
                ))}
              </div>
            </div>
          </FadeIn>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1">
          <FadeIn delay={0.3}>
            <div class="bg-white rounded-2xl shadow-lg border border-gray-100 p-6 sticky top-24">
              <h3 class="text-xl font-bold text-gray-900 mb-6">Course Information</h3>
              
              <div class="space-y-4 mb-8">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-lg bg-emerald-100 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm text-gray-500">Duration</p>
                    <p class="font-medium text-gray-900">{course.duration}</p>
                  </div>
                </div>

                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-lg bg-emerald-100 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm text-gray-500">Schedule</p>
                    <p class="font-medium text-gray-900">{course.schedule}</p>
                  </div>
                </div>

                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-lg bg-emerald-100 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm text-gray-500">Class Size</p>
                    <p class="font-medium text-gray-900">Up to {course.maxStudents} students</p>
                  </div>
                </div>

                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-lg bg-emerald-100 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm text-gray-500">Instructor</p>
                    <p class="font-medium text-gray-900">{course.instructor}</p>
                  </div>
                </div>
              </div>

              <a href="/contact" class="btn-primary w-full justify-center">
                Enroll Now
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>

              <p class="text-center text-sm text-gray-500 mt-4">
                Free consultation available
              </p>
            </div>
          </FadeIn>
        </div>
      </div>
    </div>
  </section>
</Layout>
