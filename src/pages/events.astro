---
import Layout from '../layouts/Layout.astro';
import FadeIn from '../components/animations/FadeIn.astro';
import eventsData from '../content/data/events.json';
import seoData from '../content/data/seo.json';
import { formatDate, getEventTypeLabel } from '../utils/helpers';

const { events } = eventsData;
const seo = seoData.pages.events;

const upcomingEvents = events
  .filter(e => new Date(e.date) > new Date())
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const pastEvents = events
  .filter(e => new Date(e.date) <= new Date())
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const typeColors: Record<string, string> = {
  seminar: 'bg-blue-100 text-blue-800',
  workshop: 'bg-amber-100 text-amber-800',
  conference: 'bg-purple-100 text-purple-800',
  webinar: 'bg-emerald-100 text-emerald-800',
  community: 'bg-rose-100 text-rose-800',
};
---

<Layout seo={seo}>
  <!-- Hero -->
  <section class="relative py-24 bg-gradient-to-br from-emerald-900 via-teal-900 to-emerald-800">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'0.4\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    <div class="container-custom relative z-10">
      <FadeIn class="text-center max-w-3xl mx-auto">
        <span class="badge bg-white/20 text-white mb-4">Events</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
          Upcoming Events
        </h1>
        <p class="text-xl text-emerald-100">
          Join our seminars, workshops, and conferences to deepen your knowledge and connect with the community.
        </p>
      </FadeIn>
    </div>
  </section>

  <!-- Upcoming Events -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      {upcomingEvents.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {upcomingEvents.map((event, index) => {
            const eventDate = new Date(event.date);
            const day = eventDate.getDate();
            const month = eventDate.toLocaleString('en-US', { month: 'short' });
            const year = eventDate.getFullYear();
            
            return (
              <FadeIn delay={index * 0.1}>
                <article class="h-full bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-500 border border-gray-100 hover:border-emerald-200">
                  <div class="relative h-48 bg-gradient-to-br from-emerald-500 to-teal-600 overflow-hidden">
                    <div class="absolute inset-0 flex items-center justify-center">
                      <div class="text-center text-white/90">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto mb-2 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                      </div>
                    </div>
                    <div class="absolute top-4 left-4 bg-white rounded-lg p-2 text-center min-w-[60px]">
                      <span class="block text-2xl font-bold text-emerald-600">{day}</span>
                      <span class="block text-xs text-gray-600 uppercase">{month}</span>
                    </div>
                    <div class="absolute top-4 right-4">
                      <span class={`badge ${typeColors[event.type] || 'bg-gray-100 text-gray-800'}`}>
                        {getEventTypeLabel(event.type)}
                      </span>
                    </div>
                  </div>

                  <div class="p-6">
                    <h3 class="text-xl font-bold text-gray-900 mb-2 hover:text-emerald-600 transition-colors">
                      {event.title}
                    </h3>
                    <p class="text-gray-600 text-sm mb-4 line-clamp-2">{event.description}</p>

                    <div class="space-y-2 text-sm text-gray-500 mb-6">
                      <div class="flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        {event.time}
                      </div>
                      <div class="flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        {event.location}
                      </div>
                    </div>

                    <a 
                      href={`/events/${event.id}`}
                      class="block w-full text-center py-3 rounded-lg border-2 border-emerald-600 text-emerald-600 font-medium hover:bg-emerald-600 hover:text-white transition-all duration-300"
                    >
                      {event.registrationRequired ? 'Register Now' : 'Learn More'}
                    </a>
                  </div>
                </article>
              </FadeIn>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-gray-500">Check back soon for upcoming events!</p>
        </div>
      )}
    </div>
  </section>

  <!-- Past Events -->
  {pastEvents.length > 0 && (
    <section class="section-padding bg-gray-50">
      <div class="container-custom">
        <FadeIn class="mb-12">
          <h2 class="text-3xl font-bold text-gray-900">Past Events</h2>
          <p class="text-gray-600 mt-2">Browse our previous events and programs.</p>
        </FadeIn>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {pastEvents.slice(0, 3).map((event, index) => (
            <FadeIn delay={index * 0.1}>
              <article class="h-full bg-white rounded-2xl overflow-hidden shadow-sm opacity-75 hover:opacity-100 transition-opacity">
                <div class="p-6">
                  <div class="flex items-center justify-between mb-4">
                    <span class={`badge ${typeColors[event.type] || 'bg-gray-100 text-gray-800'}`}>
                      {getEventTypeLabel(event.type)}
                    </span>
                    <span class="text-sm text-gray-500">{formatDate(event.date)}</span>
                  </div>
                  <h3 class="text-lg font-bold text-gray-900 mb-2">{event.title}</h3>
                  <p class="text-gray-600 text-sm line-clamp-2">{event.description}</p>
                </div>
              </article>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
